{
  "manifest_version": 3,
  "name": "Lumen Browser Control",
  "version": "0.1.0",
  "description": "Lets Lumen drive your real Chrome tab (read, click, scroll) over the DevTools Protocol via a local connection.",
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["debugger", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "https://127.0.0.1/*"],
  "key": ""
}
